# ── Supabase ──────────────────────────────────────────────────────────────────
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_ANON_KEY=<supabase-anon-key>
SUPABASE_SERVICE_ROLE_KEY=<supabase-service-role-key>   # never expose to browser

# ── Anthropic ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── LLM / Vision providers ────────────────────────────────────────────────────
LLM_PROVIDER=claude          # "claude" | "ollama" (ollama requires a local GPU)
VISION_PROVIDER=claude       # "claude" only in production

# ── Command search mode ───────────────────────────────────────────────────────
# Set to "true" to route /api/command through Claude NLP.
# Default (unset): fast programmatic parser — no LLM tokens consumed.
COMMAND_LLM=

# ── Google Places ─────────────────────────────────────────────────────────────
GOOGLE_PLACES_API_KEY=<google-places-api-key>
PLACES_SYNC_SECRET=<random-hex>   # protects /api/admin/* routes; match frontend value

# ── Redis ─────────────────────────────────────────────────────────────────────
# Local / Docker Compose:
REDIS_URL=redis://redis:6379
# Upstash (cloud):
# UPSTASH_REDIS_REST_URL=https://<id>.upstash.io
# UPSTASH_REDIS_REST_TOKEN=<token>

# ── Server ────────────────────────────────────────────────────────────────────
PORT=8000
NODE_ENV=development
